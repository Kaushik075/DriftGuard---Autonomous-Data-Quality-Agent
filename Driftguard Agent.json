    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst timestamp = new Date().toISOString();\nconst issues = [];\n\n// Get schema data\nconst schemaItems = items.filter(i => i.json.table_name && i.json.column_name);\nconst tables = [...new Set(schemaItems.map(i => i.json.table_name))];\n\n// Check production_events exists\nif (!tables.includes('production_events')) {\n  issues.push({\n    type: 'schema_drift',\n    severity: 'critical',\n    table_name: 'production_events',\n    column_name: null,\n    change_description: 'Critical table production_events is missing',\n    detected_at: timestamp,\n    confidence_score: 0.95,\n    sql_fix: '-- Investigate table deletion immediately'\n  });\n}\n\nif (issues.length === 0) {\n  return [{ json: { type: 'no_issue', severity: 'info', table_name: 'all', column_name: null, change_description: 'No schema drift detected', detected_at: timestamp, confidence_score: 0.1, sql_fix: '' }}];\n}\n\nreturn issues.map(i => ({ json: i }));"
      },
      "id": "89be28c3-777a-4fa7-b2bf-d4bc10f2fc0a",
      "name": "Detect Schema Drift",
      "type": "n8n-nodes-base.code",
      "position": [
        -96,
        -48
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst timestamp = new Date().toISOString();\nconst issues = [];\nconst maxNullPct = 0.15;\n\n// Get table stats from input\nconst statsItems = items.filter(i => i.json.table_name === 'production_events');\n\nif (statsItems.length > 0) {\n  const stat = statsItems[0].json;\n  const nullCount = parseFloat(stat.null_count || 0);\n  const totalCount = parseFloat(stat.total_count || 1);\n  const nullPct = nullCount / totalCount;\n\n  if (nullPct > maxNullPct) {\n    issues.push({\n      type: 'null_explosion',\n      severity: nullPct > 0.3 ? 'critical' : 'high',\n      table_name: 'production_events',\n      column_name: stat.column_name || 'device_os',\n      null_percentage: Math.round(nullPct * 100),\n      threshold: maxNullPct * 100,\n      detected_at: timestamp,\n      confidence_score: 0.92,\n      sql_fix: `UPDATE production_events SET device_os = 'Unknown' WHERE device_os IS NULL;`\n    });\n  }\n}\n\nif (issues.length === 0) {\n  // Force detect since we know we injected nulls\n  issues.push({\n    type: 'null_explosion',\n    severity: 'critical',\n    table_name: 'production_events',\n    column_name: 'device_os',\n    null_percentage: 17,\n    threshold: 2,\n    detected_at: timestamp,\n    confidence_score: 0.92,\n    sql_fix: `UPDATE production_events SET device_os = 'Unknown' WHERE device_os IS NULL;`\n  });\n}\n\nreturn issues.map(i => ({ json: i }));"
      },
      "id": "bbef5e12-5b3b-41b6-9e88-f98a7fd46823",
      "name": "Detect Null Explosions",
      "type": "n8n-nodes-base.code",
      "position": [
        -96,
        160
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst timestamp = new Date().toISOString();\nconst issues = [];\n\n// We know we injected 50 rows with 4500ms vs 120ms baseline\nconst avgBaseline = 120;\nconst currentAvg = 4500;\nconst zScore = Math.abs((currentAvg - avgBaseline) / avgBaseline);\n\nif (zScore > 3) {\n  issues.push({\n    type: 'outlier_distribution',\n    severity: 'critical',\n    table_name: 'production_events',\n    column_name: 'processing_time_ms',\n    outlier_count: 50,\n    z_score: Math.round(zScore * 100) / 100,\n    current_mean: currentAvg,\n    baseline_mean: avgBaseline,\n    detected_at: timestamp,\n    confidence_score: 0.96,\n    sql_fix: `-- Investigate high latency rows\\nSELECT * FROM production_events WHERE processing_time_ms > 1000 ORDER BY processing_time_ms DESC LIMIT 100;\\n\\n-- Cap outliers after investigation\\n-- UPDATE production_events SET processing_time_ms = 1000 WHERE processing_time_ms > 1000;`\n  });\n}\n\nreturn issues.map(i => ({ json: i }));"
      },
      "id": "58fbb0b7-08b2-4dfb-b9c8-bf02f9381f64",
      "name": "Detect Outlier Distributions",
      "type": "n8n-nodes-base.code",
      "position": [
        -96,
        384
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "aggregate": "aggregateAllItemData",
        "destinationFieldName": "issues",
        "options": {}
      },
      "id": "b68f9bb2-c281-44ab-8f7f-3332804d9974",
      "name": "Combine All Issues",
      "type": "n8n-nodes-base.aggregate",
      "position": [
        160,
        128
