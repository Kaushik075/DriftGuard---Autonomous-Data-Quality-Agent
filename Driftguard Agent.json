    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  'production_events' as table_name,\n  'device_os' as column_name,\n  COUNT(*) as total_count,\n  SUM(CASE WHEN device_os IS NULL THEN 1 ELSE 0 END) as null_count,\n  AVG(processing_time_ms) as avg_processing_time\nFROM production_events",
        "options": {}
      },
      "id": "5c2bf7ec-1a45-4ab5-80f5-8d2fec500796",
      "name": "Get Table Statistics",
      "type": "n8n-nodes-base.postgres",
