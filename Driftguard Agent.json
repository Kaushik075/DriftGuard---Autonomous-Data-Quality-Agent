        "query": "SELECT * FROM data_quality_baselines ORDER BY updated_at DESC LIMIT 1",
        "options": {}
      },
      "id": "2c18176b-aea3-4015-8acf-25abfe34dcf4",
      "name": "Get Historical Baselines",
      "type": "n8n-nodes-base.postgres",
      "position": [
        -432,
        416
      ],
      "typeVersion": 2.6,
      "credentials": {
        "postgres": {
