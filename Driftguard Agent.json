    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const issue = item.json;\n  const severity = issue.severity || 'medium';\n  \n  let severityScore = 0;\n  if (severity === 'critical') severityScore = 1.0;\n  else if (severity === 'high') severityScore = 0.8;\n  else if (severity === 'medium') severityScore = 0.5;\n  else severityScore = 0.2;\n\n  const confidenceScore = issue.confidence_score || \n    Math.round((severityScore * 0.4 + 0.3 + 0.2 + 0.1) * 1000) / 1000;\n\n  return {\n    json: {\n      ...issue.json || issue,\n      confidence_score: confidenceScore\n    }\n  };\n});;"
      },
      "id": "e827db8e-2be8-4bcc-a59b-3afd76a264dd",
      "name": "Calculate Confidence Scores",
      "type": "n8n-nodes-base.code",
      "position": [
        336,
        128
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "id-1",
              "operator": {
                "type": "array",
                "operation": "notEmpty"
              },
              "leftValue": "={{ $json.issues }}"
            },
            {
              "id": "id-2",
              "operator": {
                "type": "boolean",
                "operation": "true"
              },
              "leftValue": "={{ $json.issues.some(issue => issue.confidence_score >= $('Workflow Configuration').first().json.confidenceThreshold) }}"
            }
          ]
        },
        "options": {}
      },
      "id": "4e802e1d-5e2a-44ac-8ccf-a4aa6e9b289d",
      "name": "Check Confidence Threshold",
      "type": "n8n-nodes-base.if",
      "position": [
        496,
        128
      ],
      "typeVersion": 2.3
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const issue = item.json;\n  \n  let sqlFix = issue.sql_fix || '';\n  \n  if (!sqlFix) {\n    if (issue.type === 'null_explosion') {\n      sqlFix = `UPDATE production_events SET ${issue.column_name} = 'Unknown' WHERE ${issue.column_name} IS NULL;`;\n    } else if (issue.type === 'outlier_distribution') {\n      sqlFix = `SELECT * FROM ${issue.table_name} WHERE ${issue.column_name} > 1000 ORDER BY ${issue.column_name} DESC LIMIT 100;`;\n    } else {\n      sqlFix = `-- Review table ${issue.table_name} immediately`;\n    }\n  }\n\n  return {\n    json: {\n      ...issue,\n      sql_fix: sqlFix,\n      issueId: `DG-${Date.now()}`,\n      issueDescription: `${issue.type} detected on ${issue.table_name}.${issue.column_name || 'N/A'} with ${issue.null_percentage || issue.z_score || 0}% deviation`,\n      table: issue.table_name,\n      column: issue.column_name,\n      detectedAt: issue.detected_at,\n      sqlFix: sqlFix,\n      confidenceScore: Math.round((issue.confidence_score || 0.9) * 100)\n    }\n  };\n});"
      },
